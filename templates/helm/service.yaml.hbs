apiVersion: v1
kind: Service
metadata:
  name: {{ open }} include "{{ name }}.fullname" . {{ close }}
spec:
  type: ClusterIP
  ports:
    - port: 3000
      targetPort: 3000
      protocol: TCP
      name: http
  selector:
    app.kubernetes.io/name: {{ open }} include "{{ name }}.name" . {{ close }}
