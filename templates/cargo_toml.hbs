[package]
name = "{{ name }}"
version = "0.1.0"
edition = "2021"

[dependencies]
{{#each dependencies}}
{{this}} = { path = "../{{this}}" }
{{/each}}
{{#if (eq module_type "api")}}
tokio = { version = "1.0", features = ["full"] }
axum = "0.7"
{{/if}}
{{#if (eq module_type "worker")}}
tokio = { version = "1.0", features = ["full"] }
{{/if}}
