[package]
name = "{{ name }}"
version = "0.1.0"
edition = "2021"

[dependencies]
{{#each dependencies}}
{{this}} = { path = "../{{this}}" }
{{/each}}
{{#if (eq module_type "api")}}
tokio = { version = "1", features = ["full"] }
axum = "0.8"
tower = "0.5"
tower-http = { version = "0.6", features = ["trace", "auth", "cors"] }
jsonwebtoken = "9"
reqwest = { version = "0.13", features = ["json"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tracing = "0.1"
tracing-subscriber = "0.3"
{{/if}}
{{#if (eq module_type "worker")}}
tokio = { version = "1.0", features = ["full"] }
{{/if}}
